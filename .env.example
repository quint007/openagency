# Open Agency deployment environment contract
# Copy to `.env` in the repo root for local production/deploy operations.
# Keep real values out of git. The same keys can be mirrored into CI/CD variable stores.

# ----------------------------------------------------------------------------
# Backend runtime secrets
# ----------------------------------------------------------------------------
BACKEND_PAYLOAD_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
BACKEND_CRON_SECRET=replace-with-a-random-cron-auth-secret
BACKEND_PREVIEW_SECRET=replace-with-a-random-preview-auth-secret
BACKEND_REVALIDATE_SECRET=replace-with-a-random-revalidation-secret

# Optional operator-only external database URL. The deployed backend gets its
# DATABASE_URL from the managed Railway Postgres service instead.
BACKEND_DATABASE_URL=

# Optional alpha-stage HTTP Basic Auth gate
ALPHA_BASIC_AUTH_USERNAME=
ALPHA_BASIC_AUTH_PASSWORD=

# ----------------------------------------------------------------------------
# Production application URLs
# ----------------------------------------------------------------------------
# Backend/admin origin. Public resource links should use MARKETING_APP_BASE_URL instead.
NEXT_PUBLIC_SERVER_URL=https://admin.open-agency.io
MARKETING_APP_BASE_URL=https://open-agency.io
COURSES_APP_BASE_URL=https://courses.open-agency.io
# Optional: direct machine-to-machine revalidation origins for the backend.
# Use these when the public host is proxied and should not be used for backend-triggered revalidation.
MARKETING_REVALIDATE_URL=
COURSES_REVALIDATE_URL=
REVALIDATE_TIMEOUT_MS=5000

# ----------------------------------------------------------------------------
# Infrastructure feature toggles / identifiers
# ----------------------------------------------------------------------------
RAILWAY_ENABLED=false
RAILWAY_PROJECT_NAME=open-agency-production
VERCEL_ENABLED=false
VERCEL_TEAM=
MARKETING_VERCEL_PROJECT_NAME=open-agency-marketing
MARKETING_VERCEL_GIT_REPOSITORY=quint007/openagency
MARKETING_VERCEL_DOMAIN=open-agency.io
POSTGRES_DATABASE_NAME=open_agency
POSTGRES_USER=open_agency
R2_ENABLED=false
CLOUDFLARE_DNS_ENABLED=false
CLOUDFLARE_ZONE_NAME=open-agency.io
CLOUDFLARE_ZONE_ID=
R2_PUBLIC_HOSTNAME=media.open-agency.io

# ----------------------------------------------------------------------------
# Provider credentials
# ----------------------------------------------------------------------------
RAILWAY_TOKEN=
VERCEL_API_TOKEN=
POSTGRES_PASSWORD=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
MARKETING_PAYLOAD_API_KEY=
MARKETING_PREVIEW_PAYLOAD_API_KEY=
MARKETING_PREVIEW_REVALIDATE_SECRET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ----------------------------------------------------------------------------
# Payload R2 storage settings
# ----------------------------------------------------------------------------
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=open-agency-production-media
R2_PUBLIC_BASE_URL=https://media.example.com
R2_REGION=auto
