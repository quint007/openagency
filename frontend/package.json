{
  "name": "frontend",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test:e2e": "playwright test apps/marketing/tests/e2e",
    "test:ui": "vitest run packages/ui packages/api-client apps/marketing",
    "test": "turbo test",
    "verify:cms-boundary": "node scripts/verify-cms-client-boundary.mjs",
    "verify:course-revalidation": "playwright test --config playwright.task8.config.ts apps/courses/tests/e2e/revalidation-latency.spec.ts",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@vitejs/plugin-react": "4.5.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "jsdom": "28.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
