# Database connection string
DATABASE_URL=mongodb://127.0.0.1/your-database-name

# Or use a PG connection string
#DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Optional alpha-stage HTTP Basic Auth gate. Set both values to enable.
ALPHA_BASIC_AUTH_USERNAME=
ALPHA_BASIC_AUTH_PASSWORD=

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Used for frontend app revalidation delivery
MARKETING_APP_BASE_URL=http://localhost:3000
COURSES_APP_BASE_URL=http://localhost:3001
REVALIDATE_SECRET=YOUR_REVALIDATE_SECRET_HERE
# Optional, defaults to 5000
REVALIDATE_TIMEOUT_MS=5000

# Cloudflare R2 media storage (S3-compatible)
# Endpoint format: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=openagency-media
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
# Public read URL for media, ideally a custom domain in production
R2_PUBLIC_BASE_URL=https://media.example.com
# Optional, defaults to auto for R2
R2_REGION=auto
